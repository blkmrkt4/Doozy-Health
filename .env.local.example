# Doozy Health — local development environment.
#
# Copy this file to `.env.local` (which is git-ignored) and fill the values.
# Nothing here is a production secret: the Supabase values below are the
# well-known LOCAL demo keys printed by `supabase start` / `supabase status`.
#
# New-machine setup:
#   1. Install Node 22+, the Supabase CLI, and Docker (running).
#   2. npm install
#   3. supabase start          # applies all migrations on boot
#   4. npm run sync:drugs      # repopulates the reference drug catalogue
#   5. Create .env.local from this template (fill from `supabase status -o env`).

# From `supabase status -o env` (API_URL / ANON_KEY / SERVICE_ROLE_KEY).
# The local stack is deterministic, so these match across machines.
NEXT_PUBLIC_SUPABASE_URL="http://127.0.0.1:54321"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# App-layer encryption key for system_secrets (PRD §6.2; CLAUDE.md hard rule
# #4 — the only long-lived secret allowed in the runtime env). Generate with:
#   openssl rand -hex 32
# Not yet read by the app (the admin backend in build step 6 uses it). Once
# secrets are stored encrypted, KEEP THIS VALUE STABLE or they can't decrypt.
SECRET_ENCRYPTION_KEY=""

# Build step 6 adds the bootstrap OpenRouter key here (to seed system_secrets).
# Not needed yet.
# OPENROUTER_API_KEY=""
